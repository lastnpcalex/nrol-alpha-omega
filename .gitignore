*.pyc
logs/
briefs/
dashboards/

# Topic instance data (domain-specific, not the framework)
# Active operational topics are local working data
topics/*.json
!topics/_template.json

# Calibration topics are tracked — these are the empirical record
!topics/calibration-*.json

# Agent instructions (agent-specific, not part of the framework)
CLAUDE.md
.claude/

# Calibration data (runtime calibration history, not part of framework)
calibration/

# --- Loom mirror runtime data ---
# Activity log is per-session working data, not framework state.
# The repo ships an empty skeleton; user entries stay local.
loom/activity-log.json
!loom/activity-log.template.json

# Source DB in loom/ is a working copy of sources/source_db.json.
# Don't duplicate — users copy it in at setup time.
loom/source_db.json

# Canvas directory is the user's local Loom workspace, never committed.
canvas/

